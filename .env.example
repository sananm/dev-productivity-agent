# The platform runs fully offline with the defaults below — no API keys needed.
# Every backend is pluggable; uncomment an alternative to switch.

# --- backends --------------------------------------------------------------
LLM_BACKEND=ollama           # ollama | openai | mock
EMBEDDING_BACKEND=local      # local | openai
GITHUB_MODE=fixtures         # fixtures | live

# --- Ollama (default LLM, runs locally) -----------------------------------
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_HOST=http://localhost:11434

# --- eval judge (LLM-as-judge for the eval harness) -----------------------
# Empty = use the agent's LLM. A larger model gives more reliable LLM-judged
# scores (task completion, faithfulness) — e.g. EVAL_JUDGE_MODEL=qwen2.5:14b
EVAL_JUDGE_MODEL=

# --- local embeddings (default, runs locally) -----------------------------
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384            # 384 for bge-small; set 1536 if EMBEDDING_BACKEND=openai

# --- OpenAI (only if LLM_BACKEND/EMBEDDING_BACKEND=openai) -----------------
# OPENAI_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- GitHub (only if GITHUB_MODE=live) ------------------------------------
# GITHUB_TOKEN=ghp_...

# --- infra -----------------------------------------------------------------
DATABASE_URL=postgresql://devagent:devagent@localhost:5432/devagent
DEFAULT_REPO=psf/requests
API_BASE_URL=http://localhost:8000

# --- observability (optional; self-hosted Langfuse from docker-compose) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000
