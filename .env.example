# --- Required ---
OPENAI_API_KEY=sk-...
GITHUB_TOKEN=ghp_...

# --- Database (defaults match docker-compose.yml) ---
DATABASE_URL=postgresql://devagent:devagent@localhost:5432/devagent

# --- Models ---
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Defaults ---
DEFAULT_REPO=psf/requests
API_BASE_URL=http://localhost:8000

# --- Observability (optional; self-hosted Langfuse from docker-compose) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
